{
  "name": "t-sub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "私有的一次性 mihomo 配置交付工具，部署在 Cloudflare Workers 上。",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "npm run templates:check && npm run rules:check && node --test",
    "configs:validate": "node scripts/validate-configs.mjs",
    "templates:generate": "node scripts/generate-template-bodies.mjs",
    "templates:check": "node scripts/generate-template-bodies.mjs --check",
    "rules:generate": "node scripts/generate-rule-bodies.mjs",
    "rules:check": "node scripts/generate-rule-bodies.mjs --check",
    "rules:update": "node scripts/update-rules.mjs",
    "hash-password": "node scripts/hash-password.mjs"
  },
  "cloudflare": {
    "bindings": {
      "OWNER_PASSWORD": {
        "description": "网页登录密码。请填写你自己的密码。"
      },
      "SESSION_SECRET": {
        "description": "随机会话密钥，用于登录 cookie 签名和一次性配置加密。建议填 32 位以上随机字符串。"
      }
    }
  },
  "devDependencies": {
    "js-yaml": "^5.2.0",
    "wrangler": "^4.0.0"
  }
}
